<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="600.0" prefWidth="900.0" style="-fx-background-color: #e0e0e0;" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.controller.BidWinnerController">
    <children>
        <HBox alignment="CENTER_LEFT" prefHeight="60.0" styleClass="header-bar">
            <padding>
                <Insets left="20.0" right="20.0" />
            </padding>
            <children>
                <Button onAction="#handleBack" styleClass="header-link" text="← Quay lại" />
                <VBox alignment="CENTER" HBox.hgrow="ALWAYS">
                    <children>
                        <Label text="KẾT QUẢ ĐẤU GIÁ" textFill="WHITE">
                            <font>
                                <Font name="System Bold" size="18.0" />
                            </font>
                        </Label>
                    </children>
                </VBox>
                <Label style="-fx-font-size: 24px;" text="🏆" />
            </children>
        </HBox>

        <HBox spacing="40.0" VBox.vgrow="ALWAYS">
            <padding>
                <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
            </padding>
            <children>
                <VBox alignment="CENTER" prefWidth="400.0" styleClass="card" HBox.hgrow="NEVER">
                    <children>
                        <ImageView fx:id="itemImage" fitHeight="300.0" fitWidth="350.0" pickOnBounds="true" preserveRatio="true" />
                        <Label style="-fx-text-fill: #315cfd;" text="SOLD!">
                            <font>
                                <Font name="System Bold Italic" size="14.0" />
                            </font>
                            <VBox.margin>
                                <Insets top="15.0" />
                            </VBox.margin>
                        </Label>
                    </children>
                </VBox>

                <VBox spacing="20.0" HBox.hgrow="ALWAYS">
                    <children>
                        <Label fx:id="lblItemTitle" text="Tên Sản Phẩm" wrapText="true">
                            <font>
                                <Font name="System Bold" size="32.0" />
                            </font>
                        </Label>

                        <VBox spacing="10.0" styleClass="info-inset-container">
                            <padding>
                                <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
                            </padding>
                            <children>
                                <Label text="NGƯỜI CHIẾN THẮNG" textFill="#666666" />
                                <Label fx:id="lblWinnerName" text="Username" textFill="#315cfd">
                                    <font>
                                        <Font name="System Bold" size="28.0" />
                                    </font>
                                </Label>

                                <HBox alignment="CENTER_LEFT" spacing="10.0">
                                    <VBox.margin>
                                        <Insets top="10.0" />
                                    </VBox.margin>
                                    <children>
                                        <Label text="Giá chốt cuối cùng:" textFill="#555555" />
                                        <Label fx:id="lblFinalPrice" text="0 VNĐ" textFill="#d32f2f">
                                            <font>
                                                <Font name="System Bold" size="20.0" />
                                            </font>
                                        </Label>
                                    </children>
                                </HBox>
                            </children>
                        </VBox>

                        <VBox VBox.vgrow="ALWAYS" />

                        <HBox spacing="15.0">
                            <children>
                                <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#handleConfirm" styleClass="custom-button" text="Xác nhận &amp; Tiếp tục" HBox.hgrow="ALWAYS" />
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </HBox>
    </children>
</VBox>
