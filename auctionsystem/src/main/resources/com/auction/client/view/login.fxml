<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefHeight="300.0" prefWidth="400.0" spacing="15.0" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.controller.LoginController">

    <padding>
        <Insets bottom="20.0" left="40.0" right="40.0" top="20.0" />
    </padding>
   <HBox centerShape="false" styleClass="header-bar">
      <children>
         <Region prefHeight="38.0" prefWidth="214.0" />
      
          <Label prefHeight="38.0" prefWidth="272.0" text="HỆ THỐNG ĐẤU GIÁ" textFill="WHITE">
              <font>
                  <Font name="System Bold" size="19.0" />
              </font>
            <padding>
               <Insets top="10.0" />
            </padding>
          </Label>
         <Region prefHeight="38.0" prefWidth="189.0" />
      </children>
      <opaqueInsets>
         <Insets />
      </opaqueInsets>
      <VBox.margin>
         <Insets bottom="10.0" left="-50.0" right="-45.0" top="-25.0" />
      </VBox.margin>
   </HBox>
    <Label text="Vui lòng đăng nhập để tiếp tục" textFill="#666666" />

    <TextField fx:id="txtUsername" prefHeight="35.0" promptText="Tên đăng nhập" styleClass="input-harmonious" />

    <PasswordField fx:id="txtPassword" prefHeight="35.0" promptText="Mật khẩu" styleClass="input-harmonious" />

    <Button mnemonicParsing="false" onAction="#handleLoginAction" prefHeight="30.0" prefWidth="102.0" style="-fx-background-color: #007bff; -fx-text-fill: white;" styleClass="custom-button" text="Đăng nhập">
        <font>
            <Font name="System Bold" size="14.0" />
        </font>
    </Button>
   <Button mnemonicParsing="false" onAction="#handleTransferToRegister" styleClass="custom-button" text="Đăng kí" />

          <Label fx:id="lblMessage" textFill="RED" />

</VBox>
