<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="600.0" prefWidth="900.0" spacing="20.0" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.controller.SellerViewController">
    <children>
        <HBox alignment="CENTER_LEFT" prefHeight="60.0" styleClass="header-bar">
            <children>
                <Label text="Lịch Sử Hàng Đã Bán" textFill="WHITE">
                    <font>
                        <Font name="System Bold" size="20.0" />
                    </font>
                </Label>
                <VBox HBox.hgrow="ALWAYS" />
                <Button onAction="#handleBackToMain" styleClass="header-link" text="🏠 Quay lại" />
            </children>
            <padding>
                <Insets left="20.0" right="20.0" />
            </padding>
        </HBox>

        <VBox spacing="10.0" VBox.vgrow="ALWAYS">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="10.0" />
            </padding>
            <children>
                <Label text="Danh sách các sản phẩm đã giao dịch thành công:">
                    <font>
                        <Font size="16.0" />
                    </font>
                </Label>

                <TableView fx:id="soldItemsTable" styleClass="table-view-card" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colId" prefWidth="60.0" text="ID" />
                        <TableColumn fx:id="colItemName" prefWidth="250.0" text="Tên sản phẩm" />
                        <TableColumn fx:id="colPrice" prefWidth="150.0" text="Giá cuối (VNĐ)" />
                        <TableColumn fx:id="colSoldDate" prefWidth="180.0" text="Ngày kết thúc" />
                        <TableColumn fx:id="colBuyer" prefWidth="200.0" text="Người mua" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>
            </children>
        </VBox>
    </children>
</VBox>
