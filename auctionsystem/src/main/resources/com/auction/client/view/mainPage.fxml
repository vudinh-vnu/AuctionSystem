<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="800.0" prefWidth="1000.0" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.controller.MainPageController">
    <children>
        <HBox alignment="CENTER_LEFT" prefHeight="50.0" styleClass="header-bar">
            <children>

                <Region HBox.hgrow="ALWAYS" />
                <Button fx:id="txtusename" styleClass="header-link" text="Username" />

                <Button onAction="#handleHomeAction" styleClass="header-link" text="🏠 Home" />
                <Button onAction="#handleSellerViewTransfer" layoutX="755.0" layoutY="21.0" styleClass="header-link" text="❒Inventory" />
                <Button onAction="#handleLogoutAction" styleClass="header-link" text="🔑 Logout" />
            </children>
            <padding>
                <Insets right="20.0" />
            </padding>
        </HBox>

        <VBox alignment="TOP_CENTER" spacing="15.0" VBox.vgrow="ALWAYS">
            <children>
                <HBox alignment="CENTER_LEFT" styleClass="notification-box">
                    <children>
                        <Label prefHeight="15.0" prefWidth="554.0" text="CREATE NEW AUCTION LOT" textAlignment="CENTER" textFill="#856404" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Button onAction="#handleAddItemTransfer" prefHeight="27.0" prefWidth="231.0" styleClass="btn-white-outline" text="+ Create Auction" />
                    </children>
                </HBox>

                <HBox alignment="CENTER" spacing="0">
                    <children>
                        <fx:define>
                            <ToggleGroup fx:id="filterGroup" />
                        </fx:define>
                        <ToggleButton prefWidth="150.0" selected="true" styleClass="filter-btn, filter-btn-blue" text="All Lots" toggleGroup="$filterGroup" />
                        <ToggleButton prefWidth="150.0" styleClass="filter-btn, filter-btn-green" text="Active Lots" toggleGroup="$filterGroup" />
                        <ToggleButton prefWidth="150.0" styleClass="filter-btn, filter-btn-dark" text="My Lots" toggleGroup="$filterGroup" />
                        <ToggleButton prefWidth="150.0" styleClass="filter-btn, filter-btn-blue" text="My Bids" toggleGroup="$filterGroup" />
                        <ComboBox fx:id="cbCategory" prefWidth="150.0" promptText="Categories" styleClass="filter-combo" />
                    </children>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="20.0">
                    <children>
                        <Label text="📁 Category: All Categories" />
                    </children>
                </HBox>

                <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;" VBox.vgrow="ALWAYS">
                    <content>
                        <FlowPane fx:id="gridPaneAuctions" alignment="TOP_LEFT" hgap="20.0" vgap="20.0">
                            <padding>
                                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                            </padding>
                        </FlowPane>
                    </content>
                </ScrollPane>
            </children>
            <padding>
                <Insets bottom="20.0" left="50.0" right="50.0" top="20.0" />
            </padding>
        </VBox>
    </children>
</VBox>
