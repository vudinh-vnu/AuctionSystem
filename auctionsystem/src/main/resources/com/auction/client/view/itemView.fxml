<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox fx:id="lotCard" prefHeight="360.0" prefWidth="260.0" spacing="10.0" styleClass="card" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.controller.LotItemController">
    <children>
        <ImageView fx:id="imgProduct" fitHeight="150.0" fitWidth="230.0" pickOnBounds="true" preserveRatio="true" style="-fx-border-color: #ddd;" />

        <HBox alignment="CENTER_LEFT" spacing="5.0">
            <children>
                <Label fx:id="lblStatus" styleClass="badge-danger" text="STATUS">
                    <font><Font name="System Bold" size="10.0" /></font>
                    <padding><Insets bottom="3.0" left="6.0" right="6.0" top="3.0" /></padding>
                </Label>
                <Label fx:id="lblMyLot" managed="false" style="-fx-background-color: #DAA520; -fx-background-radius: 3px;" text="MY LOT" textFill="WHITE" visible="false">
                    <font><Font name="System Bold" size="10.0" /></font>
                    <padding><Insets bottom="3.0" left="6.0" right="6.0" top="3.0" /></padding>
                </Label>
                <Region HBox.hgrow="ALWAYS" />
            </children>
        </HBox>

        <Label fx:id="lblTitle" prefHeight="40.0" text="Item" wrapText="true" VBox.vgrow="ALWAYS">
            <font><Font name="System Bold" size="14.0" /></font>
        </Label>

        <VBox spacing="2.0">
            <children>
                <Label text="Current price:" textFill="#666666">
                    <font><Font size="11.0" /></font>
                </Label>
                <Label fx:id="txtPrice" text="Number" textFill="#0c4b8e">
                    <font><Font name="System Bold" size="16.0" /></font>
                </Label>
            </children>
        </VBox>

        <Region prefHeight="1.0" style="-fx-background-color: #eeeeee;" />

        <VBox alignment="CENTER" spacing="8.0">
            <children>
                <Button onAction="#handleDetails" prefHeight="30.0" prefWidth="230.0" styleClass="custom-button" text="DETAILS">
                    <font><Font name="System Bold" size="12.0" /></font>
                </Button>
            </children>
        </VBox>
    </children>

    <padding>
        <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
    </padding>
</VBox>
